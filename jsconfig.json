// https://www.typescriptlang.org/tsconfig/#compilerOptions
{
	"compilerOptions": {
		// if "bundler"
		// "module": "ESNext",
		"module": "NodeNext",
		// "bundler" (front), "nodenext" or "node16"
		"moduleResolution": "nodenext",
		"target": "ES2020",
		"jsx": "react",
		"checkJs": true,
		"allowImportingTsExtensions": true,
		"strictNullChecks": true,
		"strictFunctionTypes": true
	},
	"exclude": [
		"node_modules",
		"**/node_modules/*"
	]
}
